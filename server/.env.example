# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# n8n Webhooks
N8N_SAAS_WEBHOOK_URL=https://your-n8n.com/webhook/saas-pdf-process
N8N_SAAS_CHAT_WEBHOOK_URL=https://your-n8n.com/webhook/saas-chat

# n8n 回呼安全金鑰（n8n 通知處理完成時需附上）
